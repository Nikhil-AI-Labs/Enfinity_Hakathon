{
  "image_width": 952,
  "image_height": 532,
  "patch_size": 14,
  "n_classes": 10,

  "training": {
    "batch_size": 4,
    "accumulation_steps": 4,
    "n_epochs": 40,
    "phase1_epochs": 10,
    "phase2_epochs": 40,
    "lr_head": 0.0002,
    "lr_backbone_finetune": 0.000005,
    "weight_decay": 0.01,
    "early_stopping_patience": 10,
    "num_workers": 2,
    "mixed_precision": true,
    "gradient_clip_norm": 1.0
  },

  "loss": {
    "type": "ce_focal_dice",
    "class_weights": [1.0, 1.5, 1.3, 1.8, 2.5, 3.0, 3.5, 2.0, 0.7, 0.6],
    "focal_gamma": 2.0,
    "ignore_index": 255
  },

  "backbone": {
    "model1_size": "large",
    "model3_size": "large",
    "unfreeze_last_n_blocks": 6,
    "intermediate_layers": [5, 11, 17, 23]
  },

  "segformer": {
    "model_name": "nvidia/mit-b5",
    "input_size": 512,
    "lr_head": 0.0006,
    "lr_backbone": 0.00006
  },

  "augmentation": {
    "random_hflip_prob": 0.5,
    "color_jitter_brightness": 0.3,
    "color_jitter_contrast": 0.3,
    "color_jitter_saturation": 0.2,
    "color_jitter_hue": 0.1,
    "random_grayscale_prob": 0.1,
    "random_rotation_degrees": 10,
    "gaussian_blur_prob": 0.2,
    "gaussian_blur_kernel": 5,
    "normalize_mean": [0.485, 0.456, 0.406],
    "normalize_std": [0.229, 0.224, 0.225]
  },

  "classes": {
    "value_map": {"100":0, "200":1, "300":2, "500":3, "550":4, "600":5, "700":6, "800":7, "7100":8, "10000":9},
    "names": ["Trees", "Lush Bushes", "Dry Grass", "Dry Bushes", "Ground Clutter", "Flowers", "Logs", "Rocks", "Landscape", "Sky"],
    "color_palette": [
      [34, 139, 34],
      [0, 255, 0],
      [210, 180, 140],
      [139, 90, 43],
      [128, 128, 0],
      [255, 105, 180],
      [139, 69, 19],
      [128, 128, 128],
      [160, 82, 45],
      [135, 206, 235]
    ]
  },

  "paths": {
    "train_dir": "/kaggle/input/datasets/fanserudraksh/dataset/Offroad_Segmentation_Training_Dataset/Offroad_Segmentation_Training_Dataset/train",
    "val_dir":   "/kaggle/input/datasets/fanserudraksh/dataset/Offroad_Segmentation_Training_Dataset/Offroad_Segmentation_Training_Dataset/val",
    "test_dir":  "/kaggle/input/datasets/fanserudraksh/dataset/Offroad_Segmentation_testImages/Offroad_Segmentation_testImages",
    "output_base": "/kaggle/working"
  }
}
